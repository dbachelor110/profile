{
  "name": "profile",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && wrangler dev --config dist/server/wrangler.json --persist-to .wrangler/state",
    "astro": "astro",
    "deploy": "astro build && wrangler deploy --config dist/server/wrangler.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "astro check && tsc --noEmit",
    "test": "NODE_ENV=test vitest",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "test:e2e": "NODE_ENV=test playwright test",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.1",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "^14.1.1",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitest/coverage-v8": "^3.0.3",
    "astro": "^7.0.6",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-prettier": "^5.2.2",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.10",
    "tailwindcss": "^4.0.0",
    "typescript-eslint": "^8.21.0",
    "vite": "^8.1.3",
    "vitest": "^3.0.3",
    "wrangler": "^4.107.0"
  }
}
