{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*",
    "./worker-configuration.d.ts"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "strictNullChecks": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "*": [
        "./*"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "typeRoots": [
      "node_modules/@types"
    ],
    "types": [],
    "jsx": "preserve"
  }
}