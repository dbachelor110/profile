---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n/translations';

const currentLocale = 'en';
const t = translations[currentLocale];

const mockLogs = [
  'Initializing WeaverCore crawler engine...',
  'Redis proxy pool status: [OK] - 256 nodes connected',
  'Target: National Legal Database',
  'Executing multi-threaded crawl...',
  'Crawl complete. Speed: 5,400 doc/sec',
  'Running Argus-v2 verification pipeline...',
  'Data integrity check: 100% verified (0 corruptions)',
  'Dynamically compiling TypeScript SDK...',
  'SDK generated and published via semantic-release',
  'Systems status: 99.9% stable. Extraction completed in 1.2 hrs (was 3 weeks).',
];

const gitDetails = [
  { hash: 'commit 8da76c2', branch: 'origin/lawsnote' },
  { hash: 'commit e12b40d', branch: 'origin/asgard' },
  { hash: 'commit a7641f9', branch: 'origin/mores' },
];
---

<Layout>
  <!-- Hero Section -->
  <section class="hero-section" id="about">
    <div class="container grid grid-cols-1 items-center gap-12 lg:grid-cols-12">
      <!-- Intro Text -->
      <div class="flex flex-col lg:col-span-7">
        <div class="hero-eyebrow">SYSTEM STATUS: OPTIMAL // INDIVIDUAL CONTRIBUTOR</div>

        <h1 class="hero-title">
          {t.hero.title}
        </h1>

        <h2 class="hero-subtitle">
          {t.hero.subtitle}
        </h2>

        <p class="hero-desc">
          {t.hero.summary}
        </p>

        <!-- Contact Chips -->
        <div class="contact-chips">
          <span class="contact-chip">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle
                cx="12"
                cy="10"
                r="3"></circle></svg
            >
            Taipei, Taiwan (Open to Relocation / Remote)
          </span>
          <span
            class="contact-chip tooltip interactive"
            id="copy-email-btn"
            data-email="mmaoteacher@gmail.com"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path><polyline points="22,6 12,13 2,6"></polyline></svg
            >
            mmaoteacher@gmail.com
          </span>
          <a href="tel:+886985798182" class="contact-chip">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path></svg
            >
            +886 985-798-182
          </a>
          <a
            href="https://www.linkedin.com/in/尚緯-林-7216b71b5"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-chip"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"
              ></circle></svg
            >
            LinkedIn
          </a>
          <a
            href="https://github.com/dbachelor110"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-chip"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
              ></path></svg
            >
            dbachelor110
          </a>
        </div>

        <div class="hero-actions print-exclude">
          <a href="#experience" class="btn btn-primary">{t.hero.contactButton}</a>
          <button id="print-resume-btn" class="btn btn-secondary">
            <span style="font-family: var(--font-mono); margin-right: 4px;">[PDF]</span>
            {t.hero.cvButton}
          </button>
        </div>
      </div>

      <!-- Cyber Terminal/Console Mockup styled for Paper design -->
      <div class="print-exclude w-full lg:col-span-5">
        <div
          style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden;"
        >
          <!-- Terminal Title bar -->
          <div
            style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border); background-color: var(--surface-warm); padding: 8px 16px;"
          >
            <div style="display: flex; align-items: center; gap: 6px;">
              <div
                style="height: 10px; width: 10px; border-radius: 50%; background-color: #ef4444; opacity: 0.8;"
              >
              </div>
              <div
                style="height: 10px; width: 10px; border-radius: 50%; background-color: #f59e0b; opacity: 0.8;"
              >
              </div>
              <div
                style="height: 10px; width: 10px; border-radius: 50%; background-color: #10b981; opacity: 0.8;"
              >
              </div>
            </div>
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--muted);"
              >weaver-core.sh</span
            >
            <div style="width: 30px;"></div>
          </div>
          <!-- Terminal Logs -->
          <div
            style="min-height: 250px; background-color: #ffffff; padding: var(--space-4); font-family: var(--font-mono); font-size: 11px; color: var(--fg-2); line-height: 1.5; display: flex; flex-col; gap: 8px; flex-direction: column;"
          >
            {
              mockLogs.map((log, index) => (
                <div style="display: flex; align-items: flex-start; gap: 8px;">
                  <span style="color: var(--accent); user-select: none;">&gt;</span>
                  <span
                    style={
                      index === mockLogs.length - 1 ? 'font-weight: 700; color: var(--accent);' : ''
                    }
                  >
                    {log}
                  </span>
                </div>
              ))
            }
            <div style="display: flex; align-items: center; gap: 6px;" class="animate-pulse">
              <span style="color: var(--accent);">&gt;</span>
              <span
                style="height: 12px; width: 6px; background-color: var(--accent); display: inline-block;"
              ></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Skills Section -->
  <section id="skills" class="section-padding">
    <div class="container">
      <h3 class="section-title">{t.skills.title}</h3>
      <div class="section-subtitle">Core capabilities & operational tech stack</div>

      <div class="bento-grid">
        <!-- Languages -->
        <div class="bento-card">
          <div class="card-label">LANGUAGES & ENVIRONMENT</div>
          <h3 class="card-title">{t.skills.categories.languages}</h3>
          <div class="tech-list">
            {
              ['Node.js', 'TypeScript', 'JavaScript', 'SQL', 'GoLang (Familiar)'].map((skill) => (
                <span class="tech-tag">{skill}</span>
              ))
            }
          </div>
        </div>

        <!-- Frameworks -->
        <div class="bento-card">
          <div class="card-label">FRAMEWORKS & LIBRARIES</div>
          <h3 class="card-title">{t.skills.categories.frameworks}</h3>
          <div class="tech-list">
            {
              ['Koa.js', 'Express.js', 'React', 'Next.js', 'Astro', 'SolidJS'].map((skill) => (
                <span class="tech-tag">{skill}</span>
              ))
            }
          </div>
        </div>

        <!-- Databases & Infra -->
        <div class="bento-card">
          <div class="card-label">DATABASES & INFRASTRUCTURE</div>
          <h3 class="card-title">{t.skills.categories.databases}</h3>
          <div class="tech-list">
            {
              [
                'PostgreSQL',
                'MongoDB',
                'Redis',
                'Elasticsearch',
                'Docker',
                'Cloudflare (Workers, D1)',
              ].map((skill) => <span class="tech-tag">{skill}</span>)
            }
          </div>
        </div>

        <!-- Tools & Automation -->
        <div class="bento-card">
          <div class="card-label">TOOLS & AUTOMATION</div>
          <h3 class="card-title">{t.skills.categories.tools}</h3>
          <div class="tech-list">
            {
              ['Git', 'CI/CD Pipelines', 'semantic-release', 'openapi-ts', 'Swagger/OpenAPI'].map(
                (skill) => <span class="tech-tag">{skill}</span>,
              )
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Career Experience Section -->
  <section id="experience" class="section-padding">
    <div class="container">
      <h3 class="section-title">{t.experience.title}</h3>
      <div class="section-subtitle">Chronological record of production impact</div>

      <div class="git-timeline">
        {
          t.resume.jobs.map((job, index) => (
            <div class="git-commit">
              <div class="git-meta">{job.period}</div>
              <div class="git-node">
                <span class="git-dot" />
              </div>
              <div class="git-body">
                <div class="commit-header">
                  <div>
                    <span class="commit-hash">{gitDetails[index]?.hash || 'commit def1234'}</span>
                    <span class="commit-tag">{gitDetails[index]?.branch || 'origin/main'}</span>
                  </div>
                  <span class="commit-location">{job.location}</span>
                </div>
                <div class="commit-role">
                  {job.title} <span class="commit-org">@ {job.company}</span>
                </div>
                <ul class="commit-bullets">
                  {job.achievements.map((achievement) => (
                    <li>{achievement}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Education Section -->
  <section id="education" class="section-padding">
    <div class="container">
      <h3 class="section-title">{t.resume.education.title}</h3>

      <!-- Education Card -->
      <div class="bento-card">
        <div class="card-label">ACADEMIC FOUNDATION</div>
        <div
          style="display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: var(--space-2);"
        >
          <div>
            <h3 class="education-card-title">{t.resume.education.degree}</h3>
            <p class="education-card-school">{t.resume.education.school}</p>
          </div>
          {
            t.resume.education.period && (
              <span style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--muted);">
                {t.resume.education.period}
              </span>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="section-padding" style="border-bottom: none;">
    <div class="container" style="max-width: 600px;">
      <h3 class="section-title" style="text-align: center;">{t.contact.title}</h3>
      <p class="section-subtitle" style="text-align: center; margin-bottom: var(--space-8);">
        {t.contact.subtitle}
      </p>

      <form
        id="contact-form"
        style="background-color: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: var(--space-6) var(--space-8);"
      >
        <div class="form-group">
          <label for="name" class="form-label">{t.contact.name}</label>
          <input type="text" id="name" name="name" required class="form-input" />
        </div>

        <div class="form-group">
          <label for="email" class="form-label">{t.contact.email}</label>
          <input type="email" id="email" name="email" required class="form-input" />
        </div>

        <div class="form-group">
          <label for="message" class="form-label">{t.contact.message}</label>
          <textarea id="message" name="message" required class="form-input"></textarea>
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="btn btn-primary"
          style="width: 100%; display: flex; justify-content: center;"
        >
          {t.contact.send}
        </button>

        <div
          id="form-success"
          style="display: none; margin-top: var(--space-4); border: 1px solid rgba(22, 163, 74, 0.2); background-color: rgba(22, 163, 74, 0.05); color: var(--success); padding: var(--space-3) var(--space-4); text-align: center; border-radius: var(--radius-sm); font-size: var(--text-sm);"
        >
          {t.contact.success}
        </div>
      </form>
    </div>
  </section>
</Layout>

<script>
  // Copy to clipboard helper
  const copyBtn = document.getElementById('copy-email-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      const email = copyBtn.getAttribute('data-email') || '';
      navigator.clipboard
        .writeText(email)
        .then(() => {
          copyBtn.classList.add('show');
          setTimeout(() => {
            copyBtn.classList.remove('show');
          }, 1500);
        })
        .catch((err) => {
          console.error('Failed to copy: ', err);
        });
    });
  }

  // Print resume handler
  const printBtn = document.getElementById('print-resume-btn');
  if (printBtn) {
    printBtn.addEventListener('click', () => {
      window.print();
    });
  }

  // Contact Form Submission Handling
  const contactForm = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const formSuccess = document.getElementById('form-success') as HTMLDivElement;

  if (contactForm && submitBtn && formSuccess) {
    contactForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(contactForm);
      const data = {
        name: formData.get('name'),
        email: formData.get('email'),
        message: formData.get('message'),
      };

      submitBtn.disabled = true;
      const originalText = submitBtn.innerText;
      submitBtn.innerText = 'Sending...';

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          formSuccess.style.display = 'block';
          contactForm.reset();
        } else {
          alert('Failed to send message. Please try again.');
        }
      } catch (err) {
        console.error('Error sending message:', err);
        alert('An error occurred. Please try again later.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerText = originalText;
      }
    });
  }
</script>
