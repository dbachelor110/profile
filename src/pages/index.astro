---
import Layout from '../layouts/Layout.astro';
import { translations } from '../i18n/translations';

const currentLocale = Astro.currentLocale || 'zh';
const t = translations[currentLocale as 'zh' | 'en'];

const mockLogs = [
  'Initializing spider-man2 crawler engine...',
  'Redis proxy pool status: [OK] - 256 nodes connected',
  'Target: National Legal Database',
  'Executing multi-threaded crawl...',
  'Crawl complete. Speed: 5,400 doc/sec',
  'Running falcon2 verification pipeline...',
  'Data integrity check: 100% verified (0 corruptions)',
  'Dynamically compiling TypeScript SDK...',
  'SDK generated and published via semantic-release',
  'Systems status: 99.9% stable. Extraction completed in 1.2 hrs (was 3 weeks).',
];
---

<Layout>
  <!-- Hero Section -->
  <section
    class="relative flex min-h-[90vh] items-center justify-center overflow-hidden bg-radial from-slate-900 via-slate-950 to-slate-950 px-4 py-20 sm:px-6 lg:px-8"
  >
    <!-- Glowing background accents -->
    <div
      class="pointer-events-none absolute top-1/4 left-1/4 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-emerald-500/10 blur-3xl"
    >
    </div>
    <div
      class="pointer-events-none absolute right-1/4 bottom-1/4 h-[400px] w-[400px] translate-x-1/2 translate-y-1/2 rounded-full bg-cyan-500/10 blur-3xl"
    >
    </div>

    <div
      class="relative z-10 mx-auto grid w-full max-w-6xl grid-cols-1 items-center gap-12 lg:grid-cols-12"
    >
      <!-- Intro Text -->
      <div class="flex flex-col space-y-6 text-center lg:col-span-7 lg:text-left">
        <div
          class="inline-flex items-center space-x-2 self-center rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-xs font-semibold tracking-wide text-emerald-400 lg:self-start"
        >
          <span>🎯 {t.hero.greeting}</span>
        </div>

        <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
          <span
            class="bg-gradient-to-r from-emerald-400 via-teal-300 to-cyan-400 bg-clip-text text-transparent"
            >{t.hero.title}</span
          >
        </h1>

        <h2 class="text-xl font-semibold text-slate-300 sm:text-2xl">
          {t.hero.subtitle}
        </h2>

        <p class="mx-auto max-w-xl text-base leading-relaxed text-slate-400 sm:text-lg lg:mx-0">
          {t.hero.summary}
        </p>

        <div
          class="flex flex-col items-center justify-center gap-4 pt-4 sm:flex-row lg:justify-start"
        >
          <a
            href="#contact"
            class="w-full rounded-lg bg-gradient-to-r from-emerald-500 to-cyan-500 px-8 py-3 text-center font-medium text-slate-950 shadow-lg shadow-emerald-500/20 transition-all duration-300 hover:from-emerald-600 hover:to-cyan-600 hover:shadow-emerald-500/35 sm:w-auto"
          >
            {t.hero.contactButton}
          </a>
          <a
            href="https://drive.google.com/open?id=13ChytCTjI30ra4P645zif6URb3ppwDorGC3JiVVhY-A"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full rounded-lg border border-slate-700 px-8 py-3 text-center text-slate-300 transition-all duration-200 hover:border-emerald-500 hover:text-emerald-400 sm:w-auto"
          >
            {t.hero.cvButton}
          </a>
        </div>
      </div>

      <!-- Cyber Terminal/Console Mockup -->
      <div class="w-full lg:col-span-5">
        <div class="glass overflow-hidden rounded-xl border border-slate-800 shadow-2xl">
          <!-- Terminal Title bar -->
          <div
            class="flex items-center justify-between border-b border-slate-800/80 bg-slate-900/90 px-4 py-3"
          >
            <div class="flex items-center space-x-2">
              <div class="h-3 w-3 rounded-full bg-rose-500/80"></div>
              <div class="h-3 w-3 rounded-full bg-amber-500/80"></div>
              <div class="h-3 w-3 rounded-full bg-emerald-500/80"></div>
            </div>
            <span class="font-mono text-xs text-slate-500">spider-man2.sh</span>
            <div class="w-4"></div>
          </div>
          <!-- Terminal Logs -->
          <div
            class="min-h-[280px] space-y-2.5 bg-slate-950/80 p-5 font-mono text-xs text-slate-300 sm:text-sm"
          >
            {
              mockLogs.map((log, index) => (
                <div class="flex items-start space-x-2">
                  <span class="text-emerald-500 select-none">&gt;</span>
                  <span class={index === mockLogs.length - 1 ? 'font-semibold text-cyan-400' : ''}>
                    {log}
                  </span>
                </div>
              ))
            }
            <div class="flex animate-pulse items-center space-x-1.5">
              <span class="text-emerald-500">&gt;</span>
              <span class="h-4 w-2 bg-emerald-400"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="border-y border-slate-900 bg-slate-950 px-4 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <h2
        class="mb-12 flex items-center justify-center space-x-3 text-center text-3xl font-bold tracking-tight"
      >
        <span class="h-px w-8 bg-emerald-500/50"></span>
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent"
          >{t.about.title}</span
        >
        <span class="h-px w-8 bg-emerald-500/50"></span>
      </h2>

      <div class="grid grid-cols-1 items-start gap-8 md:grid-cols-3">
        <div class="space-y-6 leading-relaxed text-slate-300 md:col-span-2">
          <p>{t.about.paragraph1}</p>
          <p>{t.about.paragraph2}</p>
        </div>

        <!-- Relocation/Goal Card -->
        <div class="glass-glow rounded-xl border border-emerald-500/10 p-6">
          <h3 class="mb-3 flex items-center text-lg font-semibold text-emerald-400">
            <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 20l-5.447-2.724A2 2 0 013 15.382V6.618a2 2 0 011.18 1.894L9 11l5.447-2.724A2 2 0 0116 10.18v8.764a2 2 0 01-1.18 1.894L9 20z"
              ></path>
            </svg>
            {t.about.goalTitle}
          </h3>
          <p class="text-sm leading-relaxed text-slate-400">
            {t.about.goalText}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience Section -->
  <section id="experience" class="bg-slate-950/40 px-4 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <h2
        class="mb-16 flex items-center justify-center space-x-3 text-center text-3xl font-bold tracking-tight"
      >
        <span class="h-px w-8 bg-cyan-500/50"></span>
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent"
          >{t.experience.title}</span
        >
        <span class="h-px w-8 bg-cyan-500/50"></span>
      </h2>

      <!-- Timeline -->
      <div class="relative ml-4 space-y-12 border-l border-slate-800 md:ml-6">
        {
          t.resume.jobs.map((job) => (
            <div class="group relative pl-8 md:pl-10">
              {/* Timeline dot */}
              <div class="absolute top-1.5 -left-1.5 h-3.5 w-3.5 rounded-full border-2 border-emerald-500 bg-slate-950 transition-all duration-300 group-hover:border-cyan-400 group-hover:bg-cyan-500/20" />

              <div class="glass rounded-xl border border-slate-800 p-6 transition-all duration-200 hover:border-slate-700">
                <div class="mb-4 flex flex-col justify-between gap-2 md:flex-row md:items-center">
                  <div>
                    <h3 class="text-xl font-bold text-slate-100 transition-colors group-hover:text-emerald-400">
                      {job.company}
                    </h3>
                    <p class="mt-0.5 text-sm text-slate-400">
                      {job.title} &middot; <span class="text-slate-500">{job.location}</span>
                    </p>
                  </div>
                  <span class="inline-block self-start rounded-full border border-slate-800 bg-slate-900 px-3 py-1 text-xs whitespace-nowrap text-slate-400 md:self-center">
                    {job.period}
                  </span>
                </div>

                <ul class="text-slate-350 list-disc space-y-2.5 pl-4 text-sm leading-relaxed">
                  {job.achievements.map((achievement) => (
                    <li>{achievement}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Education Card -->
      <div
        class="mt-16 ml-4 flex items-start space-x-4 rounded-xl border border-slate-800/80 bg-slate-900/40 p-6 md:ml-6"
      >
        <div class="rounded-lg bg-emerald-500/10 p-3 text-emerald-400">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222 4 2.222V20"
            ></path>
          </svg>
        </div>
        <div>
          <h3 class="font-bold text-slate-200">{t.resume.education.title}</h3>
          <p class="mt-1 text-sm text-slate-300">{t.resume.education.school}</p>
          <p class="mt-0.5 text-xs text-slate-500">
            {t.resume.education.degree} &middot; {t.resume.education.period}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="border-y border-slate-900 bg-slate-950 px-4 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <h2
        class="mb-16 flex items-center justify-center space-x-3 text-center text-3xl font-bold tracking-tight"
      >
        <span class="h-px w-8 bg-emerald-500/50"></span>
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent"
          >{t.skills.title}</span
        >
        <span class="h-px w-8 bg-emerald-500/50"></span>
      </h2>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        <!-- Languages -->
        <div class="glass rounded-xl border border-slate-800 p-6">
          <h3 class="mb-4 flex items-center text-lg font-bold text-slate-200">
            <span class="mr-2.5 h-2 w-2 rounded-full bg-emerald-500"></span>
            {t.skills.categories.languages}
          </h3>
          <div class="flex flex-wrap gap-2.5">
            {
              ['Node.js', 'TypeScript', 'JavaScript', 'SQL', 'GoLang (Familiar)'].map((skill) => (
                <span class="rounded-lg border border-slate-800/80 bg-slate-900 px-3.5 py-1.5 text-sm text-slate-300 transition-all hover:border-emerald-500/50">
                  {skill}
                </span>
              ))
            }
          </div>
        </div>

        <!-- Frameworks -->
        <div class="glass rounded-xl border border-slate-800 p-6">
          <h3 class="mb-4 flex items-center text-lg font-bold text-slate-200">
            <span class="mr-2.5 h-2 w-2 rounded-full bg-cyan-500"></span>
            {t.skills.categories.frameworks}
          </h3>
          <div class="flex flex-wrap gap-2.5">
            {
              ['Express.js', 'React', 'Next.js', 'Astro', 'SolidJS'].map((skill) => (
                <span class="rounded-lg border border-slate-800/80 bg-slate-900 px-3.5 py-1.5 text-sm text-slate-300 transition-all hover:border-cyan-500/50">
                  {skill}
                </span>
              ))
            }
          </div>
        </div>

        <!-- Databases & Infra -->
        <div class="glass rounded-xl border border-slate-800 p-6">
          <h3 class="mb-4 flex items-center text-lg font-bold text-slate-200">
            <span class="mr-2.5 h-2 w-2 rounded-full bg-emerald-500"></span>
            {t.skills.categories.databases}
          </h3>
          <div class="flex flex-wrap gap-2.5">
            {
              [
                'PostgreSQL',
                'MongoDB',
                'Redis',
                'Elasticsearch',
                'Docker',
                'Cloudflare (Workers, D1)',
              ].map((skill) => (
                <span class="rounded-lg border border-slate-800/80 bg-slate-900 px-3.5 py-1.5 text-sm text-slate-300 transition-all hover:border-emerald-500/50">
                  {skill}
                </span>
              ))
            }
          </div>
        </div>

        <!-- Tools & Automation -->
        <div class="glass rounded-xl border border-slate-800 p-6">
          <h3 class="mb-4 flex items-center text-lg font-bold text-slate-200">
            <span class="mr-2.5 h-2 w-2 rounded-full bg-cyan-500"></span>
            {t.skills.categories.tools}
          </h3>
          <div class="flex flex-wrap gap-2.5">
            {
              ['Git', 'CI/CD Pipelines', 'semantic-release', 'openapi-ts', 'Swagger/OpenAPI'].map(
                (skill) => (
                  <span class="rounded-lg border border-slate-800/80 bg-slate-900 px-3.5 py-1.5 text-sm text-slate-300 transition-all hover:border-cyan-500/50">
                    {skill}
                  </span>
                ),
              )
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="px-4 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-xl">
      <h2
        class="mb-6 flex items-center justify-center space-x-3 text-center text-3xl font-bold tracking-tight"
      >
        <span class="h-px w-8 bg-cyan-500/50"></span>
        <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent"
          >{t.contact.title}</span
        >
        <span class="h-px w-8 bg-cyan-500/50"></span>
      </h2>

      <p class="mb-12 text-center text-sm leading-relaxed text-slate-400 sm:text-base">
        {t.contact.subtitle}
      </p>

      <form id="contact-form" class="glass space-y-6 rounded-xl border border-slate-800 p-8">
        <div>
          <label
            for="name"
            class="mb-2 block text-xs font-semibold tracking-wider text-slate-400 uppercase"
            >{t.contact.name}</label
          >
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full rounded-lg border border-slate-800 bg-slate-950 px-4 py-3 text-slate-200 placeholder-slate-600 transition-colors focus:border-emerald-500 focus:outline-none"
          />
        </div>

        <div>
          <label
            for="email"
            class="mb-2 block text-xs font-semibold tracking-wider text-slate-400 uppercase"
            >{t.contact.email}</label
          >
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full rounded-lg border border-slate-800 bg-slate-950 px-4 py-3 text-slate-200 placeholder-slate-600 transition-colors focus:border-emerald-500 focus:outline-none"
          />
        </div>

        <div>
          <label
            for="message"
            class="mb-2 block text-xs font-semibold tracking-wider text-slate-400 uppercase"
            >{t.contact.message}</label
          >
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full resize-none rounded-lg border border-slate-800 bg-slate-950 px-4 py-3 text-slate-200 placeholder-slate-600 transition-colors focus:border-emerald-500 focus:outline-none"
          ></textarea>
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full rounded-lg bg-gradient-to-r from-emerald-500 to-cyan-500 py-3.5 font-semibold text-slate-950 shadow-md shadow-emerald-500/10 transition-all duration-300 hover:from-emerald-600 hover:to-cyan-600 hover:shadow-lg hover:shadow-emerald-500/20"
        >
          {t.contact.send}
        </button>

        <div
          id="form-success"
          class="hidden rounded-lg border border-emerald-500/20 bg-emerald-500/10 p-4 text-center text-sm text-emerald-400"
        >
          {t.contact.success}
        </div>
      </form>
    </div>
  </section>
</Layout>

<script>
  const contactForm = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const formSuccess = document.getElementById('form-success') as HTMLDivElement;

  if (contactForm && submitBtn && formSuccess) {
    contactForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(contactForm);
      const data = {
        name: formData.get('name'),
        email: formData.get('email'),
        message: formData.get('message'),
      };

      submitBtn.disabled = true;
      submitBtn.innerText = 'Sending...';

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          formSuccess.classList.remove('hidden');
          contactForm.reset();
        } else {
          alert('Failed to send message. Please try again.');
        }
      } catch (err) {
        console.error('Error sending message:', err);
        alert('An error occurred. Please try again later.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerText = 'Send Message';
      }
    });
  }
</script>
