---
import { translations } from '../i18n/translations';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const currentLocale = Astro.currentLocale || 'zh';
const t = translations[currentLocale as 'zh' | 'en'];

const { title = t.meta.title, description = t.meta.description } = Astro.props;

// Calculate current path and target path for language switcher
const currentPath = Astro.url.pathname;
const isEnglish = currentLocale === 'en';
const langSwitchUrl = isEnglish
  ? currentPath.replace(/^\/en/, '') || '/'
  : `/en${currentPath === '/' ? '' : currentPath}`;
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css?family=Google+Sans:400,500|Inter:300,400,500,650,700|Fira+Code:400,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="flex min-h-screen flex-col bg-slate-950 font-sans text-slate-100 selection:bg-emerald-500/30 selection:text-emerald-300"
  >
    <!-- Header/Navbar -->
    <header class="glass sticky top-0 z-50 border-b border-slate-800/60 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <!-- Logo -->
        <a href={isEnglish ? '/en' : '/'} class="group flex items-center space-x-2">
          <span
            class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-xl font-bold text-transparent transition-all duration-300 group-hover:from-cyan-400 group-hover:to-emerald-400"
          >
            &lt;David.Lin /&gt;
          </span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden items-center space-x-8 md:flex">
          <a href="#about" class="text-sm text-slate-300 transition-colors hover:text-emerald-400"
            >{t.nav.about}</a
          >
          <a
            href="#experience"
            class="text-sm text-slate-300 transition-colors hover:text-emerald-400"
            >{t.nav.experience}</a
          >
          <a href="#skills" class="text-sm text-slate-300 transition-colors hover:text-emerald-400"
            >{t.nav.skills}</a
          >
          <a href="#contact" class="text-sm text-slate-300 transition-colors hover:text-emerald-400"
            >{t.nav.contact}</a
          >

          <!-- Lang switcher -->
          <a
            href={langSwitchUrl}
            class="rounded-full border border-slate-700 px-3 py-1.5 text-xs transition-all duration-200 hover:border-emerald-500 hover:text-emerald-400"
            id="lang-switcher"
          >
            {isEnglish ? '繁體中文' : 'English'}
          </a>
        </nav>

        <!-- Mobile Navigation Button & Language Switcher -->
        <div class="flex items-center space-x-4 md:hidden">
          <a
            href={langSwitchUrl}
            class="rounded-full border border-slate-700 px-2.5 py-1.5 text-xs transition-all duration-200 hover:border-emerald-500 hover:text-emerald-400"
            id="lang-switcher-mobile"
          >
            {isEnglish ? '中' : 'EN'}
          </a>

          <button
            type="button"
            class="text-slate-400 hover:text-slate-100 focus:outline-none"
            aria-label="Toggle menu"
            id="menu-toggle"
          >
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div class="hidden border-t border-slate-800 bg-slate-950/95 md:hidden" id="mobile-menu">
        <div class="space-y-1 px-2 pt-2 pb-4 text-center sm:px-3">
          <a
            href="#about"
            class="block rounded-md px-3 py-2 text-base font-medium text-slate-300 transition-colors hover:bg-slate-900 hover:text-emerald-400"
            >{t.nav.about}</a
          >
          <a
            href="#experience"
            class="block rounded-md px-3 py-2 text-base font-medium text-slate-300 transition-colors hover:bg-slate-900 hover:text-emerald-400"
            >{t.nav.experience}</a
          >
          <a
            href="#skills"
            class="block rounded-md px-3 py-2 text-base font-medium text-slate-300 transition-colors hover:bg-slate-900 hover:text-emerald-400"
            >{t.nav.skills}</a
          >
          <a
            href="#contact"
            class="block rounded-md px-3 py-2 text-base font-medium text-slate-300 transition-colors hover:bg-slate-900 hover:text-emerald-400"
            >{t.nav.contact}</a
          >
        </div>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-900 bg-slate-950 py-12">
      <div
        class="mx-auto flex max-w-6xl flex-col items-center justify-between px-4 sm:px-6 md:flex-row lg:px-8"
      >
        <p class="text-sm text-slate-500">
          &copy; {new Date().getFullYear()} David Lin. All rights reserved. Built with Astro 6 & Cloudflare.
        </p>
        <div class="mt-4 flex space-x-6 md:mt-0">
          <a
            href="https://github.com/dbachelor110"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-500 transition-colors hover:text-emerald-400"
            aria-label="GitHub"
          >
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"
              ><path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"></path></svg
            >
          </a>
          <a
            href="https://www.linkedin.com/in/尚緯-林-7216b71b5"
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-500 transition-colors hover:text-emerald-400"
            aria-label="LinkedIn"
          >
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"
              ><path
                fill-rule="evenodd"
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                clip-rule="evenodd"></path></svg
            >
          </a>
          <a
            href="mailto:mmaoteacher@gmail.com"
            class="text-slate-500 transition-colors hover:text-emerald-400"
            aria-label="Email"
          >
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L22 8m-9+11h.01M21 16V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2h14a2 2 0 002-2z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </footer>

    <!-- Mobile Menu Toggle Script -->
    <script>
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');

      if (menuToggle && mobileMenu) {
        menuToggle.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });

        // Close menu when clicking a link
        mobileMenu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
          });
        });
      }
    </script>
  </body>
</html>
