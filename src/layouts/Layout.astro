---
import { translations } from '../i18n/translations';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const currentLocale = Astro.url.pathname.startsWith('/en') ? 'en' : 'zh';
const t = translations[currentLocale as 'zh' | 'en'];

const { title = t.meta.title, description = t.meta.description } = Astro.props;

// Calculate current path and target path for language switcher
const basePath = Astro.url.pathname.replace(/^\/en/, '') || '/';
const isEnglish = currentLocale === 'en';
const langSwitchUrl = isEnglish ? basePath : `/en${basePath === '/' ? '' : basePath}`;

const skillsData = {
  zh: [
    { label: '程式語言與環境', value: 'Node.js, TypeScript, JavaScript, SQL, GoLang (Familiar)' },
    { label: '開發框架與套件', value: 'Koa.js, Express.js, React, Next.js, Astro, SolidJS' },
    { label: '資料庫與基礎設施', value: 'PostgreSQL, MongoDB, Redis, Elasticsearch, Docker, Cloudflare (Workers, D1)' },
    { label: '開發工具與自動化', value: 'Git, CI/CD Pipelines, semantic-release, openapi-ts, Swagger/OpenAPI' },
    { label: 'AI 原生與代理工作流', value: 'Claude Code, GitHub Copilot, Cursor, Context Engineering, Model Context Protocol (MCP) 客製伺服器整合' }
  ],
  en: [
    { label: 'Languages', value: 'Node.js, TypeScript, JavaScript, SQL, GoLang (Familiar)' },
    { label: 'Frameworks & Libraries', value: 'Koa.js, Express.js, React, Next.js, Astro, SolidJS' },
    { label: 'Databases & Infrastructure', value: 'PostgreSQL, MongoDB, Redis, Elasticsearch, Docker, Cloudflare (Workers, D1)' },
    { label: 'Tools & Automation', value: 'Git, CI/CD Pipelines, semantic-release, openapi-ts, Swagger/OpenAPI' },
    { label: 'AI-Native & Agentic Workflows', value: 'Claude Code, GitHub Copilot, Cursor, Context Engineering, Model Context Protocol (MCP) custom server integration' }
  ]
};
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <!-- Header Nav -->
    <header data-od-id="nav-header">
      <div class="nav-container">
        <a href={isEnglish ? '/en' : '/'} class="brand-logo" data-od-id="nav-brand">
          <img src="/favicon.png" alt="D. LIN Logo" />
          <span>D. LIN</span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden items-center gap-6 md:flex">
          <a href="#about" class="nav-link">{t.nav.about}</a>
          <a href="#skills" class="nav-link">{t.nav.skills}</a>
          <a href="#experience" class="nav-link">{t.nav.experience}</a>
          <a href="#contact" class="nav-link">{t.nav.contact}</a>

          <!-- Lang switcher -->
          <a
            href={langSwitchUrl}
            id="lang-switcher"
            class="nav-link"
            style="border: 1px solid var(--border); padding: 4px 10px; border-radius: var(--radius-sm);"
          >
            {isEnglish ? '繁體中文' : 'English'}
          </a>
        </nav>

        <!-- Mobile Navigation Button & Language Switcher -->
        <div class="flex items-center gap-4 md:hidden">
          <a
            href={langSwitchUrl}
            id="lang-switcher-mobile"
            class="nav-link"
            style="border: 1px solid var(--border); padding: 4px 8px; border-radius: var(--radius-sm);"
          >
            {isEnglish ? '中' : 'EN'}
          </a>

          <button
            type="button"
            class="cursor-pointer text-[#111111] hover:text-[var(--accent)] focus:outline-none"
            aria-label="Toggle menu"
            id="menu-toggle"
          >
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div class="hidden md:hidden" id="mobile-menu">
        <div class="border-t border-[var(--border)] bg-white py-2">
          <a href="#about" class="mobile-menu-link">{t.nav.about}</a>
          <a href="#skills" class="mobile-menu-link">{t.nav.skills}</a>
          <a href="#experience" class="mobile-menu-link">{t.nav.experience}</a>
          <a href="#contact" class="mobile-menu-link">{t.nav.contact}</a>
        </div>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer data-od-id="terminal-footer">
      <div class="footer-container">
        <div class="footer-meta">
          &copy; {new Date().getFullYear()} DAVID LIN // BUILT WITH EXTREME RESTRAINT.
        </div>
        <div class="footer-links">
          <a
            href="https://github.com/dbachelor110"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link"
          >
            GitHub
          </a>
          <a
            href="https://www.linkedin.com/in/尚緯-林-7216b71b5"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link"
          >
            LinkedIn
          </a>
          <a href="mailto:mmaoteacher@gmail.com" class="footer-link"> Email </a>
        </div>
      </div>
    </footer>

    <!-- Print-only resume document -->
    <div class="print-only-resume">
      <div class="print-header">
        <div class="print-name">{isEnglish ? "SHANG-WEI (DAVID) LIN" : "林尚緯 (Shang-Wei Lin)"}</div>
        <p class="print-subtitle">{isEnglish ? "Taipei, Taiwan (Open to Relocation / Remote)" : "台灣台北 (接受遠端/移居)"}</p>
        <p class="print-contact">
          mmaoteacher@gmail.com | +886 985-798-182 | 
          <a href="https://www.linkedin.com/in/尚緯-林-7216b71b5" target="_blank">linkedin.com/in/David-Lin</a> | 
          <a href="https://github.com/dbachelor110" target="_blank">github.com/dbachelor110</a>
        </p>
      </div>

      <div class="print-section">
        <div class="print-section-title">{isEnglish ? "PROFESSIONAL SUMMARY" : "專業總覽"}</div>
        <div class="print-section-line"></div>
        <p>{isEnglish ? "Senior Backend Engineer specializing in data reliability, scalable pipelines, and engineering efficiency. Passionate about tackling complex architecture bottlenecks in high-caliber teams." : "專精於數據可靠性、高併發管道與工程效率的資深後端工程師。在解決複雜的架構瓶頸與建構健壯的自動化解決方案（從多執行緒爬蟲系統到 CI/CD SDK 自動生成）方面有深厚經驗。熱衷於作為個人貢獻者 (IC) 在高效團隊中解決具挑戰性的數據基礎設施瓶頸。"}</p>
      </div>

      <div class="print-section">
        <div class="print-section-title">{isEnglish ? "TECHNICAL SKILLS" : "專業技能"}</div>
        <div class="print-section-line"></div>
        <div class="print-skills">
          {skillsData[currentLocale].map(skill => (
            <p>
              <strong>{skill.label}:</strong> {skill.value}
            </p>
          ))}
        </div>
      </div>

      <div class="print-section">
        <div class="print-section-title">{isEnglish ? "WORK EXPERIENCE" : "工作經歷"}</div>
        <div class="print-section-line"></div>
        
        {t.resume.jobs.map(job => (
          <div class="print-job">
            <div class="print-job-header">
              <span class="print-company"><strong>{job.company}</strong></span>
              <span class="print-location">{job.location}</span>
            </div>
            <div class="print-job-subheader">
              <span class="print-job-title"><em>{job.title}</em></span>
              <span class="print-job-period"><em>{job.period}</em></span>
            </div>
            <ul class="print-achievements">
              {job.achievements.map(ach => (
                <li>
                  {ach.includes(': ') ? (
                    <>
                      <strong>{ach.split(': ')[0]}:</strong>
                      {ach.split(': ').slice(1).join(': ')}
                    </>
                  ) : (
                    ach
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="print-section" style="page-break-inside: avoid;">
        <div class="print-section-title">{isEnglish ? "EDUCATION" : "學歷"}</div>
        <div class="print-section-line"></div>
        <div class="print-job">
          <div class="print-job-header">
            <span class="print-company"><strong>{t.resume.education.school}</strong></span>
          </div>
          <div class="print-job-subheader">
            <span class="print-job-title"><em>{t.resume.education.degree}</em></span>
            {t.resume.education.period && (
              <span class="print-job-period"><em>{t.resume.education.period}</em></span>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Menu Toggle Script -->
    <script>
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');

      if (menuToggle && mobileMenu) {
        menuToggle.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });

        // Close menu when clicking a link
        mobileMenu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
          });
        });
      }
    </script>
  </body>
</html>
